# Copy this file to .env or export these variables in your shell.
# Never commit real credentials.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Optional local Hugging Face model configuration
CBELIEF_HF_MODEL=
CBELIEF_HF_TRUST_REMOTE_CODE=false
